<IfModule mod_rewrite.c>
    RewriteEngine On

    # --------------------------------------------------
    # Core hardening
    # --------------------------------------------------

    Options -Indexes
    ServerSignature Off

    # --------------------------------------------------
    # Force HTTPS (skip localhost)
    # --------------------------------------------------

    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost$ [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # --------------------------------------------------
    # Redirect handling (RAW passthrough)
    # --------------------------------------------------
    # Rules:
    # - Only handle root requests (/)
    # - Do NOT touch /redirect.php directly
    # - Pass the full raw request to PHP
    # --------------------------------------------------

    # Skip redirect.php to prevent loops
    RewriteRule ^redirect\.php$ - [L]

    # Only act on root requests with something after ?
    RewriteCond %{REQUEST_URI} ^/$
    RewriteCond %{QUERY_STRING} .+

    # Forward raw request to PHP (NO parsing, NO decoding)
    RewriteRule ^$ /redirect.php [L]

    # --------------------------------------------------
    # Custom error pages
    # --------------------------------------------------

    ErrorDocument 404 /404.html
    ErrorDocument 500 /500.html

    # --------------------------------------------------
    # Security headers
    # --------------------------------------------------

    <IfModule mod_headers.c>
        Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Header always set X-Frame-Options "DENY"
        Header always set X-Content-Type-Options "nosniff"
        Header always set Referrer-Policy "no-referrer"
        Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

        # CSP safe for inline JS/CSS
        Header always set Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self'; base-uri 'none'; form-action 'self'; frame-ancestors 'none'"

        # Prevent caching of redirect responses
        Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header always set Pragma "no-cache"
    </IfModule>
</IfModule>

